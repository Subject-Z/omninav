---
interface Props {
  isEmpty?: boolean;
  emptyMessage?: string;
}

const { isEmpty = false, emptyMessage = "No content available for this year" } = Astro.props;
---

<div class="content-list">
  {isEmpty ? (
    <div class="empty-state">
      {emptyMessage}
    </div>
  ) : (
    <slot />
  )}
</div>

<style>
  .content-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin: 0 auto;
  }
  
  .empty-state {
    margin: 3rem auto;
    padding: 3rem 1rem;
    text-align: center;
    color: #777;
    font-size: 1.2rem;
    grid-column: 1 / -1;
  }
  
  /* 响应式布局 */
  @media (max-width: 768px) {
    .content-list {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
    }
  }
  
  @media (max-width: 480px) {
    .content-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>