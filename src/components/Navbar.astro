---
const currentPath = Astro.url.pathname;
const isZh = currentPath.startsWith('/zh');

function getLanguageSwitchUrl() {
  if (currentPath === '/' || currentPath === '/zh/') {
    return isZh ? '/' : '/zh/';
  }
  
  const pathParts = currentPath.split('/').filter(Boolean);
  const basePath = isZh ? pathParts.slice(1) : pathParts;
  
  return isZh ? `/${basePath.join('/')}` : `/zh/${basePath.join('/')}`;
}

function getHomeUrl() {
  return isZh ? '/zh/' : '/';
}
---

<nav class="Navbar">
  <div class="navbar-container">
    <div class="navbar-center">
      <div class="site-logo">
        <a href={getHomeUrl()} class="logo-link">
          OmniNav
        </a>
      </div>
      
      <div class="search-box">
        <form action="https://www.google.com/search" method="get" target="_blank" class="search-form">
          <input 
            type="text" 
            name="q" 
            placeholder={isZh ? "搜索..." : "Search..."} 
            aria-label={isZh ? "搜索" : "Search"}
            class="search-input"
            autocomplete="off"
          />
          <input type="hidden" name="q" value="site:omninav.uk" />
          <button 
            type="submit" 
            aria-label={String(isZh ? "搜索" : "Search")}
            class="search-btn"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <path d="M21 21l-4.35-4.35"/>
            </svg>
          </button>
        </form>
      </div>
      
      <div class="language-switch">
        <div class="lang-container">
          <a href={getLanguageSwitchUrl()} class="lang-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="lang-icon">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
              <path d="M2 12h20"/>
              <path d="M12 2a15.3 15.3 15.3 0 0 1 4 10 15.3 15.3 15.3 0 0 1-4 10 15.3 15.3 15.3 0 0 1-4-10 15.3 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            {isZh ? "English" : "中文"}
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  .Navbar {
    position: absolute;
    top: 0;
    width: 100%;
    padding: 1rem 0;
  }
  
  .navbar-container {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 90%;
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .navbar-center {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }
  
  .site-logo {
    margin-right: 0.5rem;
    width: 20%;
  }
  
  .logo-link {
    font-size: 1.5rem;
    font-weight: 700;
    color: #333;
    text-decoration: none;
    transition: color 0.2s ease;
    padding: 1rem 0;
    display: block;
    text-align: left;
  }

  .search-box {
    position: relative;
    flex-grow: 1;
    width: 60%;
    max-width: none;
  }

  .search-form {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-input {
    width: 100%;
    height: 3rem;
    padding: 0 3.5rem 0 1.5rem;
    border-radius: 2rem;
    border: 1px solid #e0e0e0;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .search-input:focus {
    outline: none;
    border-color: #4a90e2;
    box-shadow: 0 0 0 3px rgba(74, 144, 226, 0.2);
  }

  .search-btn {
    position: absolute;
    right: 0;
    height: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 1.5rem;
    color: #666;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-btn:hover {
    color: #4a90e2;
  }

  .language-switch {
    width: 20%;
  }

  .lang-container {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 0.5rem 0;
  }

  .lang-btn {
    color: #555;
    text-decoration: none;
    font-weight: 500;
    font-size: 1.2rem;
    transition: color 0.2s ease;
    display: flex;
    padding: 0.5rem 0 0.5rem 1rem;
    align-items: center;
    gap: 0.5rem;
  }
  
  .lang-btn:hover {
    color: #4a90e2;
  }
  
  .lang-icon {
    flex-shrink: 0;
    color: currentColor;
    width: 18px;  /* 增加到18px以便更好地显示细节 */
    height: 18px;
  }

  /* 添加媒体查询，在移动设备上隐藏 logo */
  @media (max-width: 768px) {
    .site-logo {
      display: none;
    }
    
    .navbar-center {
  margin: 0 1rem;
 gap: 0.5rem 
}

    .search-box {
      width: 75%; /* 调整搜索框宽度 */
    }
    
    .language-switch {
      width: 25%; /* 调整语言切换区域宽度 */
    }
  }
</style>