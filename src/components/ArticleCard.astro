---
// 导入需要的类型
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, pubDate, image, lang } = article.data;

// 格式化日期
function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}

// 获取文章链接
function getArticleLink(): string {
  // 从article.id中提取文件名部分(不包含分类)
  const filename = article.id.split('/').pop() || '';
  const slug = filename.replace(/\.(en|zh)\.md$/, '');
  
  // 构建完整路径(包含articles目录)
  const basePath = lang === 'zh' ? `/zh/articles` : `/articles`;
  return `${basePath}/${slug}`;
}

// 准备显示的日期
const displayDate = formatDate(pubDate);

// 获取默认图片（如果未提供）
const displayImage = image || '/favicon.webp';
---

<div class="article-card">
  <a href={getArticleLink()} class="article-link">
    <div class="article-image">
      <img src={displayImage} alt={title} />
    </div>
    <div class="article-content">
      <h2 class="article-title">{title}</h2>
      <p class="article-description">{description}</p>
      <div class="article-meta">
        <span class="article-date">{displayDate}</span>
      </div>
    </div>
  </a>
</div>

<style>
  .article-card {
    max-width: 90%;
    background-color: #f5f2ec;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 250px; /* 固定卡片高度 */
    margin: 0 auto 2rem; /* 左右居中并保留底部间距 */
    border-radius: 8px; /* 可选：添加圆角使卡片更美观 */
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08); /* 可选：添加轻微阴影 */
  }

  .article-link {
    display: flex;
    flex-direction: row; /* 水平布局 - 左图右文 */
    color: inherit;
    text-decoration: none;
    height: 100%;
    width: 100%;
  }

  /* 图片区域调整 */
  .article-image {
    width: 35%; /* 固定图片区域宽度比例 */
    min-width: 150px; /* 设置最小宽度 */
    height: 100%; /* 设置为100%以填充整个卡片高度 */
    overflow: hidden;
    position: relative;
  }

  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .article-image::after {
    content: "READ MORE";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6); /* 半透明黑色遮罩 */
    color: white; /* 白色文字 */
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0; /* 默认不可见 */
    transition: opacity 0.3s ease;
    font-weight: 600;
    font-size: 2rem;
    letter-spacing: 1px;
  }

  .article-card:hover .article-image::after {
    opacity: 1; /* 悬停时显示遮罩 */
  }

  /* 文字内容区域调整 */
  .article-content {
    flex: 1; /* 占据剩余空间 */
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }

  .article-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: #333;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-description {
    color: #666;
    font-size: 0.95rem;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-meta {
    font-size: 0.85rem;
    color: #888;
    margin-top: auto; /* 将元数据推到底部 */
  }

  .article-date {
    display: inline-block;
    margin-right: 0.25rem;
  }

  /* 移动端响应式布局 */
  @media (max-width: 768px) {
    .article-card {
      max-width: 95%; /* 略微增加移动端下的卡片宽度 */
    }
    
    .article-title {
      font-size: 1.3rem; /* 调整标题大小 */
      margin-bottom: 0.5rem;
    }
    
    .article-description {
      -webkit-line-clamp: 2; /* 限制描述文本行数 */
    }
  }
  
  /* 425px-768px的平板布局 - 左右结构 */
  @media (min-width: 426px) and (max-width: 768px) {
    .article-card {
      height: 200px; /* 稍微降低卡片高度 */
    }
    
    .article-link {
      flex-direction: row; /* 保持水平布局 */
    }
    
    .article-image {
      width: 40%; /* 调整图片区域宽度 */
      min-width: 120px;
      height: 100%;
    }
    
    .article-content {
      padding: 1rem;
    }
  }
  
  /* 425px及以下的小屏幕布局 - 上下结构 */
  @media (max-width: 425px) {
    .article-card {
      height: auto; /* 取消固定高度，根据内容自适应 */
    }
    
    .article-link {
      flex-direction: column; /* 垂直布局 - 上图下文 */
    }
    
    .article-image {
      width: 100%; /* 图片占满宽度 */
      height: 180px; /* 设置图片高度 */
      min-width: auto; /* 移除最小宽度限制 */
    }
    
    .article-content {
      padding: 1rem; /* 减少内边距 */
      min-height: 150px; /* 确保内容区域有足够的高度 */
    }
  }
</style>
