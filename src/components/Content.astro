---
import type { CollectionEntry } from "astro:content";

type AnyCollectionEntry = CollectionEntry<
  keyof import("astro:content").DataEntryMap
>;

interface Props {
  entry: AnyCollectionEntry;
}

const { entry } = Astro.props;
const { Content: EntryContent } = await entry.render();
const tags = entry.data.tags || [];
---

<article class="content-detail">
  <div class="content-body">
    <EntryContent />
  </div>
</article>

<script define:vars={{ tags }}>
  document.addEventListener("DOMContentLoaded", () => {
    const imageTextBlocks = document.querySelectorAll(".image-text-block");
    imageTextBlocks.forEach((block) => {
      const tagsContainer = block.querySelector(".content-tags");
      if (tagsContainer) {
        tagsContainer.innerHTML = "";
        tags.forEach((tag) => {
          const tagSpan = document.createElement("span");
          tagSpan.className = "tag";
          tagSpan.textContent = tag;
          tagsContainer.appendChild(tagSpan);
        });
      }
    });
    
    const contentBlocks = document.querySelectorAll(".content-block");
    contentBlocks.forEach((block) => {
      const tagsContainer = block.querySelector(".content-tags");
      if (tagsContainer) {
        tagsContainer.innerHTML = "";
        tags.forEach((tag) => {
          const tagSpan = document.createElement("span");
          tagSpan.className = "tag";
          tagSpan.textContent = tag;
          tagsContainer.appendChild(tagSpan);
        });
      }
    });

    // 添加图片错误处理
    const contentImages = document.querySelectorAll(".image-text-block img");
    contentImages.forEach(img => {
      img.onerror = function() {
        this.classList.add("error");
        this.src = "/images/image-placeholder.webp"; // 替换为占位图的路径
      };
    });

    // 为中文标题添加横线
    const chineseTitles = document.querySelectorAll(".chinese-title");
    chineseTitles.forEach(title => {
      const divider = document.createElement("hr");
      divider.className = "title-divider";
      title.insertAdjacentElement('afterend', divider);
    });
  });
</script>

<style is:global>
  .content-detail {
    margin: 5rem auto;
    background-color: #f5f2ec;
    border-radius: 8px;
    padding: 2rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .content-body p {
    margin-bottom: 1.5rem;
  }

  .content-body h1 {
    margin-top: 0;
  }
  
  .english-title {
    color: #8b2e2e;
    font-size: 1.8rem;
    font-weight: 600;
    display: block;
    margin-bottom: 0.5rem;
  }
  
  .chinese-title {
    color: #333;
    font-size: 1.4rem;
    font-weight: 500;
    display: block;
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
  }
  
  .title-divider {
    border: 0;
    height: 1px;
    background-color: #E6E1D6;
    margin: 0.5rem 0 1.5rem;
    width: 100%;
  }
  
  .content-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0 2rem;
  }
  
  .content-tags .tag {
    background: #E6E1D6;
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    color: #555;
    display: inline-block;
  }
  
  .image-text-block {
    display: flex;
    align-items: flex-start;
    gap: 25px;
    clear: both;
    margin-bottom: 3rem;
  }

  .image-text-block:last-child {
    margin-bottom: 0;
  }

  .image-container {
    flex-basis: 50%;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background-color: #f0f0f0; /* 占位背景色 */
    height: auto; /* 自动高度 */
  }
  
  .image-text-block img {
    position: relative; /* 改为相对定位而非绝对定位 */
    width: 100%;
    height: auto; /* 自动高度，保持图片比例 */
    object-fit: cover;
    border-radius: 8px;
    display: block; /* 避免底部间隙 */
  }

  /* 添加图片加载失败的备用样式 */
  .image-text-block img.error {
    object-fit: contain;
    background-color: #f5f5f5;
  }

  .image-text-block .text-content {
    flex: 1;
  }

  @media (max-width: 768px) {
    .content-detail {
      padding: 1.5rem;
    }
    
    .coupon-list {
      width: 100%;
    }
    
    .english-title {
      font-size: 1.5rem;
    }
    
    .chinese-title {
      font-size: 1.2rem;
    }
  }
  
  @media (max-width: 425px) {
    .image-text-block {
      flex-direction: column;
      gap: 15px;
    }
    
    .image-container {
      width: 100%;
    }
    
    .text-content {
      width: 100%;
    }
    
    .image-text-block img {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      display: block;
      margin-bottom: 10px;
    }
  }
</style>