---
import type { CollectionEntry } from "astro:content";

type AnyCollectionEntry = CollectionEntry<
  keyof import("astro:content").DataEntryMap
>;

interface Props {
  entry: AnyCollectionEntry;
}

const { entry } = Astro.props;
const { Content: EntryContent } = await entry.render();
const tags = entry.data.tags || [];
---

<article class="content-detail">
  <div class="content-body">
    <EntryContent />
  </div>
</article>

<script define:vars={{ tags }}>
  document.addEventListener("DOMContentLoaded", () => {
    const imageTextBlocks = document.querySelectorAll(".image-text-block");
    imageTextBlocks.forEach((block) => {
      const chineseTitle = block.querySelector(".chinese-title");
      if (chineseTitle) {
        let tagsContainer = document.createElement("div");
        tagsContainer.className = "content-tags";
        tags.forEach((tag) => {
          const tagSpan = document.createElement("span");
          tagSpan.className = "tag";
          tagSpan.textContent = tag;
          tagsContainer.appendChild(tagSpan);
        });
        chineseTitle.insertAdjacentElement('afterend', tagsContainer);
      }
    });
    
    const contentBlocks = document.querySelectorAll(".content-block");
    contentBlocks.forEach((block) => {
      const chineseTitle = block.querySelector(".chinese-title");
      if (chineseTitle) {
        let tagsContainer = document.createElement("div");
        tagsContainer.className = "content-tags";
        tags.forEach((tag) => {
          const tagSpan = document.createElement("span");
          tagSpan.className = "tag";
          tagSpan.textContent = tag;
          tagsContainer.appendChild(tagSpan);
        });
        chineseTitle.insertAdjacentElement('afterend', tagsContainer);
      }
    });

    const contentImages = document.querySelectorAll(".image-text-block img");
    contentImages.forEach(img => {
      img.onerror = function() {
        this.classList.add("error");
        this.src = "/images/image-placeholder.webp";
      };
    });

    const textContentChineseTitles = document.querySelectorAll(".text-content .chinese-title");
    textContentChineseTitles.forEach(title => {
      const divider = document.createElement("hr");
      divider.className = "title-divider";
      
      const nextElement = title.nextElementSibling;
      if (nextElement && nextElement.classList.contains("content-tags")) {
        nextElement.insertAdjacentElement('afterend', divider);
      } else {
        title.insertAdjacentElement('afterend', divider);
      }
    });
  });
</script>

<style is:global>
  .content-detail {
    margin: 8rem auto;
    background-color: #f5f2ec;
    border-radius: 8px;
    padding: 2rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .title {
    font-size: 2.2rem;
    color: #8b2e2e;
  }

  .content-body p {
    margin-bottom: 1.5rem;
  }

  .content-body h1 {
    margin-top: 0;
  }
  
  .english-title {
    color: #8b2e2e;
    font-size: 2rem;
    font-weight: 600;
    display: block;
    margin-bottom: 0.5rem;
  }
  
  .chinese-title {
    color: #333;
    font-size: 1.4rem;
    font-weight: 500;
    display: block;
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
  }
  
  .title-divider {
    border: 0;
    height: 1px;
    background-color: #E6E1D6;
    margin: 0.5rem 0 1.5rem;
    width: 100%;
  }
  
  .content-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0;
  }
  
  .content-tags .tag {
    background: #E6E1D6;
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    color: #555;
    display: inline-block;
  }
  
  .english-description {
    font-size: 1.1rem;
    line-height: 1.5em;
  }

  .image-text-block {
    display: flex;
    align-items: flex-start;
    gap: 25px;
    clear: both;
    margin-bottom: 3rem;
  }

  .image-text-block:last-child {
    margin-bottom: 0;
  }

  .image-container {
    flex-basis: 50%;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background-color: #f0f0f0;
    height: auto;
  }
  
  .image-text-block img {
    position: relative;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  .image-text-block img.error {
    object-fit: contain;
    background-color: #f5f5f5;
  }

  .image-text-block .text-content {
    flex: 1;
  }

  .coupon-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .coupon-item {
    background: linear-gradient(135deg, #fff5ea 0%, #ffefdc 100%);
    border-radius: 10px;
    padding: 16px 18px;
    position: relative;
    box-shadow: 0 3px 10px rgba(255, 107, 107, 0.1);
    transition: all 0.3s ease;
    border-left: 5px solid #ff6b6b;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .coupon-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(255, 107, 107, 0.15);
    background: linear-gradient(135deg, #fff2e3 0%, #ffe6c9 100%);
  }

  .coupon-item:before {
    content: "";
    position: absolute;
    left: -5px;
    top: 0;
    height: 100%;
    width: 5px;
    background: linear-gradient(to bottom, #ff5252, #ff8b8b);
  }

  .coupon-item:after {
    content: "";
    position: absolute;
    right: -6px;
    top: 50%;
    transform: translateY(-50%);
    width: 12px;
    height: 12px;
    border-right: 2.5px solid #ff6b6b;
    border-bottom: 2.5px solid #ff6b6b;
    rotate: -45deg;
  }

  .coupon-item a.coupon-description {
    color: #333;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.05rem;
    display: block;
    padding-right: 25px;
    transition: all 0.2s ease;
  }

  .coupon-item a.coupon-description:hover {
    color: #e94949;
  }

  .coupon-item::before {
    content: "";
    position: absolute;
    left: -5px;
    height: 100%;
    width: 5px;
    top: 0;
    background: linear-gradient(to bottom, #ff5252, #ff8b8b);
  }

  .coupon-item::after {
    content: "";
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 12px;
    height: 12px;
    border-right: 2.5px solid #ff6b6b;
    border-bottom: 2.5px solid #ff6b6b;
    rotate: -45deg;
    transition: all 0.2s ease;
  }

  .coupon-item:hover::after {
    right: 8px;
    border-right: 2.5px solid #e94949;
    border-bottom: 2.5px solid #e94949;
  }

  @media (max-width: 768px) {
    .content-detail {
      padding: 1.5rem;
    }
    
    .coupon-list {
      width: 100%;
      gap: 14px;
    }
    
    .english-title {
      font-size: 1.5rem;
    }
    
    .chinese-title {
      font-size: 1.2rem;
    }
    
    .coupon-item {
      padding: 12px 15px;
    }

    .coupon-item a.coupon-description {
      font-size: 0.95rem;
    }

    .title {
      font-size: 1.8rem;
    }
  }
  
  @media (max-width: 425px) {
    .image-text-block {
      flex-direction: column;
      gap: 15px;
    }
    
    .image-container {
      width: 100%;
    }
    
    .text-content {
      width: 100%;
    }
    
    .image-text-block img {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      display: block;
      margin-bottom: 10px;
    }
    
    .coupon-item {
      padding: 10px 12px;
    }

    .coupon-item a.coupon-description {
      font-size: 0.9rem;
      padding-right: 20px;
    }
    
    .coupon-item::after {
      width: 10px;
      height: 10px;
      right: 10px;
    }
    
    .coupon-item:hover::after {
      right: 7px;
    }
    
    .title {
      font-size: 1.6rem;
    }
  }
</style>