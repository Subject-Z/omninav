---
import type { CollectionEntry } from "astro:content";
import { type ContentEntry } from "../content/config";

type AnyCollectionEntry = CollectionEntry<keyof import("astro:content").DataEntryMap>;

interface Props {
  entry: AnyCollectionEntry;
}

const { entry } = Astro.props;
const { Content: EntryContent } = await (entry as ContentEntry).render();
const tags = Array.isArray(entry.data.tags)
  ? entry.data.tags
  : entry.data.tags
    ? [entry.data.tags]
    : [];
const englishTitle = entry.data.title || "";
const chineseTitle = entry.data.chineseTitle || "";
---

<article class="content-detail">
  <div class="content-header">
    <div class="title-container">
      <h1 class="english-title">{englishTitle}</h1>
      {chineseTitle && <div class="chinese-title">{chineseTitle}</div>}
      <div class="tags-container">
        {
          tags.map((tag: string, index: number) => (
            <>
              <span class="tag">{tag}</span>
              {index < tags.length - 1 && <span class="tag-separator">/</span>}
            </>
          ))
        }
      </div>
    </div>
  </div>

  <div class="content-body">
    <EntryContent />
  </div>
</article>

<script>
  function handleImages() {
    const allImages = document.querySelectorAll('img');
    
    allImages.forEach(img => {
      img.onerror = function() {
        this.classList.add("error");
        this.src = "/images/image-placeholder.webp";
      };
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    const contentBlocks = document.querySelectorAll(
      ".content-block, .image-text-block",
    );
    contentBlocks.forEach((block) => {
      block.classList.add("content-section");
    });

    handleImages();
  });

  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.type === 'childList') {
        const addedNodes = Array.from(mutation.addedNodes);
        if (addedNodes.some(node => 
          node.nodeName === 'IMG' || 
          (node.nodeType === 1 && (node as Element).querySelector('img'))
        )) {
          handleImages();
        }
      }
    });
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });
</script>

<style is:global>
  .content-detail {
    max-width: 1000px;
    margin: 7rem auto;
    padding: 40px 20px;
    background-color: #f5f2ec;
    border-radius: 8px;
  }

  .content-header {
    text-align: center;
    margin-bottom: 50px;
    padding-bottom: 30px;
    border-bottom: 1px solid #d4b483;
  }

  .title-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin-bottom: 20px;
  }

  .chinese-title {
    font-size: 2rem;
    font-weight: 700;
    color: #8b2e2e;
    letter-spacing: 5px;
    padding-bottom: 10px;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #5a3921;
    margin: 0 auto 20px;
    line-height: 1.5;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #5a3921;
    margin: 0 auto 20px;
  }

  p, li {
    font-size: 1.3rem;
    line-height: 1.7;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-top: 15px;
  }

  .tag {
    font-size: 0.9rem;
  }

  .tag-separator {
    color: #5a3921;
    margin: 0 2px;
  }

  .content-section {
    display: block;
    margin-bottom: 40px;
  }

  .content-section .text-content {
    padding: 0;
    margin-bottom: 20px;
  }

  .content-section .image-container {
    padding: 0;
    margin-bottom: 20px;
    display: block;
    text-align: center;
  }

  .content-section img {
    max-width: 500px;
    height: auto;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .content-section img.error {
    object-fit: contain;
    background-color: #f5f5f5;
  }

  img {
    display: block;
    max-width: 500px;
    height: auto;
    margin: 2rem auto;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  h2 {
    color: #8b2e2e;
    font-size: 1.5rem;
    margin-top: 0;
  }

  h3 {
    font-size: 1.4rem;
  }

  p {
    text-align: justify;
    margin-bottom: 20px;
  }

  .content-body h1,
  .content-body h2,
  .content-body h3 {
    color: #8b2e2e;
  }

  a {
    color: #4a90e2;
    text-decoration: none;
    transition: text-decoration 0.2s ease;
  }

  a:hover {
    text-decoration: underline;
  }

  .content-body {
    max-width: 900px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .tags-container {
      margin-top: 10px;
    }

    .tag {
      font-size: 0.8rem;
    }

    h1 {
      font-size: 1.2rem;
    }
    h2 {
      font-size: 1.1rem;
    }

    .tag {
      font-size: 0.8rem;
    }

    .chinese-title {
      font-size: 0.9rem;
    }

    p {
      font-size: 0.9rem;
    }

    .content-detail {
      margin: 5rem auto;
    }

    .content-section img {
      max-width: 300px;
    }

    img {
      max-width: 300px;
    }
  }
</style>