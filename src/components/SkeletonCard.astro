---
// 骨架屏卡片组件
interface Props {
  category?: string;
  slug?: string;
  image?: string; // 添加图片属性
  title?: string; // 添加标题属性用于alt
}

const { category = "", slug = "", image = "", title = "加载中..." } = Astro.props;

// 生成文章链接，如果提供了category和slug则使用它们，否则使用#作为占位符
const articleLink = category && slug ? `/${category}/${slug}` : "#";
---

<a href={articleLink} class="skeleton-card-link">
  <div class="skeleton-card">
    <div class="skeleton-image">
      {image && (
        <img
          data-src={image}
          alt={title}
          class="lazy-image"
          loading="lazy"
          onload="this.classList.add('loaded'); this.parentElement.classList.add('loaded');"
        />
      )}
    </div>
    <div class="skeleton-content">
      <div class="skeleton-title"></div>
      <div class="skeleton-tags">
        <span></span>
        <span></span>
      </div>
    </div>
  </div>
</a>

<style>
  .skeleton-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .skeleton-card {
    break-inside: avoid; /* 防止卡片在多列布局中被分割 */
    margin-bottom: 1.5rem;
    background: #f0ece5;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .skeleton-card-link:hover .skeleton-card {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
  }

  .skeleton-image {
    width: 100%;
    height: 0;
    padding-bottom: 56.25%; /* 16:9 宽高比的占位符 */
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    position: relative;
    overflow: hidden;
  }
  
  .lazy-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .lazy-image.loaded {
    opacity: 1;
  }
  
  .skeleton-image.loaded {
    animation: none;
    background: none;
  }

  .skeleton-content {
    padding: 1rem;
  }

  .skeleton-title {
    height: 24px;
    width: 80%;
    margin-bottom: 0.75rem;
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    border-radius: 4px;
  }

  .skeleton-tags {
    display: flex;
    gap: 0.5rem;
  }

  .skeleton-tags span {
    height: 18px;
    width: 60px;
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    border-radius: 4px;
  }

  @keyframes shimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
</style>

<script>
  // 为瀑布流布局中的懒加载图片添加支持
  document.addEventListener('DOMContentLoaded', () => {
    // 确保代码运行在浏览器环境中
    if (typeof document !== 'undefined') {
      // 监听交叉观察器，当图片进入视口时加载
      if ('IntersectionObserver' in window) {
        const lazyImageObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const lazyImage = entry.target as HTMLImageElement;
              if (lazyImage.dataset.src) {
                lazyImage.src = lazyImage.dataset.src;
                lazyImage.removeAttribute('data-src');
              }
              observer.unobserve(lazyImage);
            }
          });
        });

        // 为所有懒加载图片添加观察器
        document.querySelectorAll('img.lazy-image').forEach(img => {
          lazyImageObserver.observe(img);
        });
      } else {
        // 对于不支持交叉观察器的浏览器，使用滚动事件的备用方案
        let lazyLoadThrottleTimeout: ReturnType<typeof setTimeout> | null = null;
        
        function lazyLoad() {
          if (lazyLoadThrottleTimeout) {
            clearTimeout(lazyLoadThrottleTimeout);
          }

          lazyLoadThrottleTimeout = setTimeout(() => {
            const scrollTop = window.scrollY;
            const lazyImages = document.querySelectorAll('img.lazy-image[data-src]');
            
            lazyImages.forEach(img => {
              const imgElement = img as HTMLImageElement;
              const rect = imgElement.getBoundingClientRect();
              
              if (rect.top <= window.innerHeight && rect.bottom >= 0) {
                imgElement.src = imgElement.dataset.src || '';
                imgElement.removeAttribute('data-src');
              }
            });
            
            if (lazyImages.length === 0) {
              document.removeEventListener('scroll', lazyLoad);
              window.removeEventListener('resize', lazyLoad);
              window.removeEventListener('orientationchange', lazyLoad);
            }
          }, 20);
        }

        document.addEventListener('scroll', lazyLoad);
        window.addEventListener('resize', lazyLoad);
        window.addEventListener('orientationchange', lazyLoad);
        // 初次加载页面时检查
        setTimeout(lazyLoad, 0);
      }
    }
  });
</script>