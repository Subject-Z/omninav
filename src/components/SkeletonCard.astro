---
// 骨架屏卡片组件
interface Props {
  category?: string;
  slug?: string;
}

const { category = "", slug = "" } = Astro.props;

// 生成文章链接，如果提供了category和slug则使用它们，否则使用#作为占位符
const articleLink = category && slug ? `/${category}/${slug}` : "#";
---

<a href={articleLink} class="skeleton-card-link">
  <div class="skeleton-card">
    <div class="skeleton-image"></div>
    <div class="skeleton-content">
      <div class="skeleton-title"></div>
      <div class="skeleton-tags">
        <span></span>
        <span></span>
      </div>
    </div>
  </div>
</a>

<style>
  .skeleton-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .skeleton-card {
    break-inside: avoid; /* 防止卡片在多列布局中被分割 */
    margin-bottom: 1.5rem;
    background: #f0ece5;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .skeleton-card-link:hover .skeleton-card {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
  }

  .skeleton-image {
    width: 100%;
    height: 0;
    padding-bottom: 56.25%; /* 16:9 宽高比的占位符 */
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
  }

  .skeleton-content {
    padding: 1rem;
  }

  .skeleton-title {
    height: 24px;
    width: 80%;
    margin-bottom: 0.75rem;
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    border-radius: 4px;
  }

  .skeleton-tags {
    display: flex;
    gap: 0.5rem;
  }

  .skeleton-tags span {
    height: 18px;
    width: 60px;
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    border-radius: 4px;
  }

  @keyframes shimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
</style>