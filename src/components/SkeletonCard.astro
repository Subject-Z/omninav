---
import BaseCard from './BaseCard.astro';

interface Props {
  category?: string;
  slug?: string;
  image?: string;
  title?: string;
}

const { 
  category = "", 
  slug = "", 
  image = "", 
  title = "加载中..." 
} = Astro.props;

const articleLink = category && slug ? `/${category}/${slug}` : "#";
---

<a href={articleLink} class="skeleton-link">
  <BaseCard wrapperClass="skeleton-card-wrapper" cardClass="skeleton-card">
    <div class="skeleton-image">
      {image && (
        <img
          data-src={image}
          alt={title}
          class="lazy-image"
          loading="lazy"
          onload="this.classList.add('loaded'); this.parentElement.classList.add('loaded');"
        />
      )}
    </div>
    <div class="card-content">
      <div class="skeleton-title"></div>
      <div class="skeleton-tags">
        <span></span>
        <span></span>
      </div>
    </div>
  </BaseCard>
</a>

<style>
  .skeleton-link {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .skeleton-image {
    width: 100%;
    height: 0;
    padding-bottom: 56.25%;
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    position: relative;
    overflow: hidden;
  }

  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  
  .lazy-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .lazy-image.loaded {
    opacity: 1;
  }
  
  .skeleton-image.loaded {
    animation: none;
    background: none;
  }

  .skeleton-title {
    height: 24px;
    width: 80%;
    margin-bottom: 0.75rem;
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    border-radius: 4px;
  }

  .skeleton-tags {
    display: flex;
    gap: 0.5rem;
  }

  .skeleton-tags span {
    height: 18px;
    width: 60px;
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    border-radius: 4px;
  }
</style>