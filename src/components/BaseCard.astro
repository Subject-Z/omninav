---
interface Props {
  wrapperClass?: string;
  cardClass?: string;
}

const { 
  wrapperClass = "",
  cardClass = ""
} = Astro.props;
---

<div class={`card-wrapper ${wrapperClass}`}>
  <div class={`card ${cardClass}`}>
    <slot />
  </div>
</div>

<style>
  .card-wrapper {
    width: 100%;
    transform: translateY(20px);
    opacity: 0;
    animation: fade-in 0.5s forwards;
    break-inside: avoid;
    margin-bottom: 1.5rem;
  }

  @keyframes fade-in {
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .card {
    height: 100%;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  /* 卡片内容区域 */
  :global(.card-content) {
    padding: 1rem;
    display: flex;
    flex-direction: column;
  }

  /* 图片容器 */
  :global(.card-image-container) {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* 响应式调整 */
  @media screen and (max-width: 768px) {
    :global(.card-content) {
      padding: 0.5rem;
    }
  }
</style>