---
interface Props {
  title?: string;
  image?: string;
  category?: string;
  slug?: string;
  wrapperClass?: string;
  showCategory?: boolean;
}

const {
  title = '',
  image = '',
  category = '',
  slug = '',
  wrapperClass = '',
  showCategory = false,
} = Astro.props;

const articleLink = category && slug ? `/${category}/${slug}` : "#";
import { categoryNames } from '../content/config';
---

<div class={`card-wrapper ${wrapperClass}`}>
  <div class="card">
    <a href={articleLink} class="card-link">
      {image && (
        <div class="card-image-container">
          <div class="aspect-ratio-box">
            <div class="image-placeholder"></div>
            <img
              src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'%3E%3C/svg%3E"
              data-src={image}
              alt={title}
              class="card-image lazy" 
              loading="lazy" 
              width={400} 
              height={300}
            />
            {showCategory && category && (
              <div class="category-tag">
                {categoryNames[category as keyof typeof categoryNames] || category}
              </div>
            )}
          </div>
        </div>
      )}
      <h2 class="card-title">{title}</h2>
    </a>
  </div>
</div>

<style>
  .card-wrapper {
    width: 100%;
    break-inside: avoid;
    display: block;
    position: relative;
    transition: opacity 0.3s ease;
  }

  .card {
    overflow: hidden;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: auto;
  }

  .card-title {
    margin: 0.5rem auto 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: #333;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    height: auto;
    min-height: 3rem;
    line-height: 1.5;
    position: relative;
    flex: 1;
  }

  .card-image-container {
    border-radius: 8px;
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #E6E1D6;
    flex: 0 0 auto;
  }
  
  .aspect-ratio-box {
    position: relative;
    width: 100%;
    padding-bottom: 150%;
  }
  
  .image-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f0f0f0;
    z-index: 1;
  }
  
  .card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 2;
    transition: transform 0.3s ease, opacity 0.3s ease;
    opacity: 0;
  }
  
  .card-image.loaded {
    opacity: 1;
  }
  
  .card-link:hover .card-image {
    transform: scale(1.05);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-link:hover .card {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }
  
  .category-tag {
    position: absolute;
    bottom: 10px;
    right: 10px;
    background-color: rgba(0, 0, 0, 0.6);
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
    z-index: 3;
    text-transform: capitalize;
    transition: background-color 0.3s ease;
  }

  @media screen and (max-width: 768px) {
    .card-title {
      font-size: 1rem;
      -webkit-line-clamp: 2;
    }
    
    .category-tag {
      font-size: 0.7rem;
      padding: 3px 6px;
    }
  }
  
  @media screen and (max-width: 480px) {
    .card-title {
      font-size: 0.9rem;
      font-weight: 500;
    }
    
    .category-tag {
      font-size: 0.65rem;
      padding: 2px 5px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const lazyImages = document.querySelectorAll('img.lazy');
    
    if ('IntersectionObserver' in window) {
      const imageObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target as HTMLImageElement;
            const imgSrc = img.dataset.src;
            if (imgSrc) {
              img.src = imgSrc;
              img.onload = () => {
                img.classList.add('loaded');
                img.previousElementSibling?.remove();
              };
            }
            imageObserver.unobserve(img);
          }
        });
      }, {
        rootMargin: '50px 0px',
        threshold: 0.1
      });
      
      lazyImages.forEach(img => {
        imageObserver.observe(img);
      });
    } else {
      lazyImages.forEach(img => {
        const imgElement = img as HTMLImageElement;
        const imgSrc = imgElement.dataset.src;
        if (imgSrc) {
          imgElement.src = imgSrc;
          imgElement.classList.add('loaded');
        }
      });
    }
  });
</script>