---
// 导入配置
import { categoryNames, validCategories } from '../content/config';
import type { CategoryKey } from '../content/config';

// 获取当前路径，用于高亮当前分类
const pathname = Astro.url.pathname;
const currentCategory = pathname.split('/')[1] || '';
---

<header class="header">
  <div class="nav-container">
    <nav class="nav">
      <div class="nav-scroller">
        <ul class="nav-list" id="navList">
          <!-- 添加Home链接 -->
          <li class="nav-item">
            <a 
              href="/"
              class={`nav-link ${pathname === '/' ? 'active' : ''}`}
            >
              <span class="category-name">Home</span>
            </a>
          </li>
          {validCategories.map((category) => {
            const categoryKey = category as CategoryKey;
            return (
              <li class="nav-item">
                <a 
                  href={`/${category}`}
                  class={`nav-link ${currentCategory === category ? 'active' : ''}`}
                >
                  <span class="category-name">
                    {categoryNames[categoryKey] || category}
                  </span>
                </a>
              </li>
            );
          })}
          <!-- 添加联系我们链接 -->
          <li class="nav-item">
            <a 
              href="/contact"
              class={`nav-link ${currentCategory === 'contact' ? 'active' : ''}`}
            >
              <span class="category-name">Contact</span>
            </a>
          </li>
        </ul>
      </div>
    </nav>
  </div>
</header>

<style>
  .header {    
    position: absolute;
    width: 100%;
  }

  .nav-container {
    max-width: min(95vw, 1000px);
    margin: 0 auto;

  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }
  
  .nav-scroller {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch; /* 增强iOS的滚动体验 */
    scrollbar-width: none; /* 隐藏Firefox滚动条 */
  }
  
  .nav-scroller::-webkit-scrollbar {
    display: none; /* 隐藏Chrome/Safari滚动条 */
  }

  .nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1rem;
    align-items: center;
    white-space: nowrap; /* 防止项目换行 */
  }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    text-decoration: none;
    color: #333;
    font-weight: 500;
    font-size: 1.2rem;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    color: #8b2e2e;
    background-color: transparent;
  }

  .nav-link.active {
    color: #8b2e2e;
    background-color: transparent;
    font-weight: 600;
  }

  /* 响应式设计 */
  @media (max-width: 768px) {
    .nav-container {
      width: 100%;
    }
    
    .nav-list {
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }
    
    .nav-item:first-child {
      margin-left: 0;
    }
    
    .nav-item:last-child {
      margin-right: 0;
      padding-right: 1rem; /* 确保最后一项有足够的右侧空间 */
    }
  }
</style>