---
interface Props {
  title: string;
  description: string;
  image?: string;
  date: Date;
  tags?: string[];
  slug: string;
  category: string;
}

const { title, description, image, date, tags = [], slug, category } = Astro.props;

// 生成文章链接
const articleLink = `/${category}/${slug}`;
---

<div class="content-card-wrapper">
  <a href={articleLink} class="card-link">
    <div class="content-card">
      {image && (
        <div class="card-image-container">
          <div class="skeleton-placeholder"></div>
          <img 
            src={image} 
            alt={title}
            class="card-image" 
            loading="lazy" 
            onload="this.style.opacity='1'; this.previousElementSibling.style.display='none';"
          />
        </div>
      )}
      <div class="card-content">
        <h2 class="card-title">{title}</h2>
        <div class="card-meta">
          <div class="card-tags">
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </a>
</div>

<style>
  .content-card-wrapper {
    width: 100%;
    margin-bottom: 1rem;
    transform: translateY(20px);
    opacity: 0;
    animation: fade-in 0.5s forwards;
  }
  
  @keyframes fade-in {
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  
  .content-card {
    height: 100%;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .card-link:hover .content-card {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
  }
  
  .card-image-container {
    position: relative;
    width: 100%;
    height: 40vh;
    overflow: hidden;
  }

  @media screen and (max-width: 768px) {
    .card-image-container {
      height: 25vh;
    }
  }

  .skeleton-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, #eee 8%, #f5f5f5 18%, #eee 33%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite linear;
    z-index: 1;
  }
  
  .card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 2;
  }

  @keyframes shimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
  
  .card-content {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
    height: 120px;
    position: relative;
  }
  
  .card-title {
    margin: 0 0 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: #333;
    max-height: 3.5rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  
  .card-meta {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
  }
  
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  
  .tag {
    background: #f0ece5;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.7rem;
  }
</style>