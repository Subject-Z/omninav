---
import Card from "./Card.astro";

interface Props {
  items: Array<{
    title?: string;
    image?: string;
    tags?: string[];
    category?: string;
    slug?: string;
    date?: Date | string;
  }>;
  columns?: {
    default: number;
    desktop: number;
    tablet: number;
    mobile: number;
  };
  gap?: string;
  className?: string;
  showCategory?: boolean;
}

const { 
  items = [],
  columns = { default: 4, desktop: 3, tablet: 3, mobile: 2 },
  gap = "2rem",
  className = "",
  showCategory = false,
} = Astro.props;

const sortedItems = [...items]
  .sort((a, b) => {
    const dateA = a.date ? new Date(a.date).getTime() : 0;
    const dateB = b.date ? new Date(b.date).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 12);
---

<div class="grid-container">
  <div class={`responsive-grid ${className}`}>
    {sortedItems.map((item) => (
      <Card
        title={item.title}
        image={item.image}
        category={item.category}
        slug={item.slug}
        showCategory={showCategory}
      />
    ))}
  </div>
</div>

<style define:vars={{ 
  gap, 
  defaultColumns: columns.default, 
  desktopColumns: columns.desktop, 
  tabletColumns: columns.tablet, 
  mobileColumns: columns.mobile 
}}>
  .grid-container {
    position: relative;
    width: 100%;
  }

  .responsive-grid {
    display: grid;
    margin: 8rem auto 3rem;
    grid-template-columns: repeat(var(--defaultColumns), minmax(0, 1fr));
    gap: var(--gap);
    width: 100%;
  }

  @media (max-width: 1200px) {
    .responsive-grid {
      grid-template-columns: repeat(var(--desktopColumns), minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .responsive-grid {
      margin: 6rem auto;
      grid-template-columns: repeat(var(--tabletColumns), minmax(0, 1fr));
      gap: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .responsive-grid {
      grid-template-columns: repeat(var(--mobileColumns), minmax(0, 1fr));
    }
  }
</style>

<script>
  function handleImageLoaded() {
    document.querySelectorAll('.card-img-container img').forEach(img => {
      if (img instanceof HTMLImageElement) {
        if (img.complete) {
          const skeleton = img.closest('.card-img-container')?.querySelector('.skeleton-loader');
          if (skeleton) skeleton.classList.add('loaded');
        } else {
          img.addEventListener('load', () => {
            const skeleton = img.closest('.card-img-container')?.querySelector('.skeleton-loader');
            if (skeleton) skeleton.classList.add('loaded');
          });
        }
      }
    });
  }
  
  document.addEventListener('DOMContentLoaded', handleImageLoaded);
  
  // 为可能的动态加载内容添加 MutationObserver
  const observer = new MutationObserver(mutations => {
    for (const mutation of mutations) {
      if (mutation.type === 'childList' && mutation.addedNodes.length) {
        handleImageLoaded();
      }
    }
  });
  
  observer.observe(document.body, {
    childList: true,
    subtree: true
  });
</script>