---
interface Props {
  isEmpty?: boolean;
  emptyMessage?: string;
  columns?: number;
}

const { 
  isEmpty = false, 
  emptyMessage = "暂无内容", 
  columns = 4 
} = Astro.props;
---

<div class="content-list" data-columns={columns}>
  {isEmpty ? (
    <div class="empty-state">
      {emptyMessage}
    </div>
  ) : (
    <slot />
  )}
</div>

<style define:vars={{ columns }}>
  .content-list {
    display: grid;
    grid-template-columns: repeat(var(--columns), 1fr);
    gap: 1.5rem;
    margin: 0 auto;
  }
  
  .empty-state {
    margin: 3rem auto;
    padding: 3rem 1rem;
    text-align: center;
    color: #777;
    font-size: 1.2rem;
    grid-column: 1 / -1;
  }
  
  @media (max-width: 1024px) {
    .content-list {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }
  
  @media (max-width: 480px) {
    .content-list {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
    }
  }
</style>