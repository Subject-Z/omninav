---
import { initLazyLoading } from '../utils/lazyLoad.js';

interface Props {
  initialLoadCount?: number;
  adInterval?: number;
  columns?: number;
}

const { 
  initialLoadCount = 12,
  adInterval = 4,
  columns = 4
} = Astro.props;

// 导入广告卡片组件
import AdCard from "./AdCard.astro";
---

<div class="masonry-container">
  <div class="masonry-grid" 
       data-initial-load={initialLoadCount} 
       data-item-selector=".card-wrapper"
       data-ad-interval={adInterval}
       data-columns={columns}>
    <slot />
  </div>
  <div class="loading-indicator">
    <div class="spinner"></div>
    <span>加载更多内容...</span>
  </div>
</div>

<!-- 广告模板 -->
<template id="ad-template" style="display:none">
  <AdCard />
</template>

<style define:vars={{ columns }}>
  .masonry-grid {
    display: grid;
    grid-template-columns: repeat(var(--columns, 4), 1fr);
    gap: 1.5rem;
    margin: 0 auto;
  }

  .loading-indicator {
    display: none;
    justify-content: center;
    align-items: center;
    padding: 2rem 0;
    text-align: center;
    color: #666;
    gap: 0.5rem;
  }

  .spinner {
    width: 20px;
    height: 20px;
    border: 2px solid #ccc;
    border-top-color: #2A5CAA;
    border-radius: 50%;
    animation: spinner 0.8s linear infinite;
  }

  @keyframes spinner {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 1024px) {
    .masonry-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .masonry-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  import { setupLazyLoading } from '../utils/lazyLoad';

  document.addEventListener('DOMContentLoaded', () => {
    // 初始化懒加载
    setupLazyLoading();
    
    const masonryGrid = document.querySelector('.masonry-grid');
    if (!masonryGrid) return;

    const initialLoadCount = parseInt(masonryGrid.getAttribute('data-initial-load') || '12');
    const itemSelector = masonryGrid.getAttribute('data-item-selector') || '.card-wrapper';
    const adInterval = parseInt(masonryGrid.getAttribute('data-ad-interval') || '4');
    const loadingIndicator = document.querySelector('.loading-indicator');
    const adTemplate = document.querySelector('#ad-template');
    
    // 获取所有内容项
    const allItems = Array.from(document.querySelectorAll(itemSelector)).filter(
      item => !item.classList.contains('ad-card-wrapper')
    );
    
    let visibleCount = 0;
    let loading = false;

    // 初始化布局并插入广告
    function initLayout() {
      // 隐藏所有内容项
      allItems.forEach(item => {
        item.style.display = 'none';
      });

      // 显示初始内容并插入广告
      loadBatch(initialLoadCount, true);
      
      // 显示或隐藏加载指示器
      if (loadingIndicator) {
        loadingIndicator.style.display = hasMoreContent() ? 'flex' : 'none';
      }
    }

    // 加载一批内容
    function loadBatch(count, isInitial = false) {
      const nextBatch = Math.min(allItems.length - visibleCount, count);
      let contentLoaded = 0;
      
      for (let i = 0; contentLoaded < nextBatch && (visibleCount + contentLoaded) < allItems.length; i++) {
        // 检查是否需要插入广告
        if (!isInitial && (visibleCount + contentLoaded) > 0 && 
            (visibleCount + contentLoaded) % adInterval === 0) {
          insertAd();
        }
        
        // 显示下一个内容项
        const itemToShow = allItems[visibleCount + contentLoaded];
        if (itemToShow) {
          itemToShow.style.display = '';
          contentLoaded++;
        }
      }
      
      visibleCount += contentLoaded;
      
      // 初始布局时插入广告
      if (isInitial) {
        for (let i = adInterval; i < visibleCount; i += adInterval) {
          insertAdAt(i);
        }
      }
    }

    // 在当前位置插入广告
    function insertAd() {
      const currentItems = Array.from(masonryGrid.children);
      insertAdAt(currentItems.length);
    }
    
    // 在指定位置插入广告
    function insertAdAt(position) {
      if (!adTemplate) return;
      
      const adNode = adTemplate.content.cloneNode(true);
      const adWrapper = document.createElement('div');
      adWrapper.className = 'ad-card-wrapper';
      adWrapper.appendChild(adNode);
      
      const items = Array.from(masonryGrid.children);
      
      if (position >= items.length) {
        masonryGrid.appendChild(adWrapper);
      } else {
        masonryGrid.insertBefore(adWrapper, items[position]);
      }
      
      // 初始化广告代码
      const adScript = document.createElement('script');
      adScript.textContent = '(adsbygoogle = window.adsbygoogle || []).push({});';
      adWrapper.appendChild(adScript);
    }

    // 检查是否有更多内容
    function hasMoreContent() {
      return visibleCount < allItems.length;
    }

    // 加载更多内容
    function loadMoreContent() {
      if (loading || !hasMoreContent()) return;
      
      loading = true;
      if (loadingIndicator) loadingIndicator.style.display = 'flex';

      // 模拟加载延迟
      setTimeout(() => {
        loadBatch(8);  // 每次加载8个
        
        loading = false;
        
        if (loadingIndicator) {
          loadingIndicator.style.display = hasMoreContent() ? 'flex' : 'none';
        }
      }, 500);
    }

    // 监听滚动事件
    function handleScroll() {
      if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 800) {
        loadMoreContent();
      }
    }

    // 添加滚动监听
    window.addEventListener('scroll', handleScroll);
    
    // 初始化布局
    initLayout();
  });
</script>