---
// 瀑布流布局组件
interface Props {
  initialLoadCount?: number; // 初始加载的条目数量
  itemSelector?: string; // 条目选择器
}

const { 
  initialLoadCount = 12,
  itemSelector = ".content-card-wrapper" 
} = Astro.props;
---

<div class="masonry-container">
  <div class="masonry-grid" data-initial-load={initialLoadCount} data-item-selector={itemSelector}>
    <slot />
  </div>
  <div class="loading-indicator">
    <div class="spinner"></div>
    <span>加载更多内容...</span>
  </div>
</div>

<style>
  .masonry-container {
    width: 100%;
    margin: 0 auto;
    position: relative;
  }

  .masonry-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin: 0 auto;
  }

  .loading-indicator {
    display: none;
    justify-content: center;
    align-items: center;
    padding: 2rem 0;
    text-align: center;
    color: #666;
    gap: 0.5rem;
  }

  .spinner {
    width: 20px;
    height: 20px;
    border: 2px solid #ccc;
    border-top-color: #2A5CAA;
    border-radius: 50%;
    animation: spinner 0.8s linear infinite;
  }

  @keyframes spinner {
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 768px) {
    .masonry-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .masonry-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const masonryGrid = document.querySelector('.masonry-grid');
    if (!masonryGrid) return;

    const initialLoadCount = parseInt(masonryGrid.getAttribute('data-initial-load') || '12');
    const itemSelector = masonryGrid.getAttribute('data-item-selector') || '.content-card-wrapper';
    const loadingIndicator = document.querySelector('.loading-indicator') as HTMLElement;
    
    // 获取所有内容项
    const allItems = Array.from(document.querySelectorAll(itemSelector));
    let visibleCount = initialLoadCount;
    let loading = false;

    // 初始隐藏超出初始加载数量的项目
    allItems.forEach((item, index) => {
      if (index >= initialLoadCount) {
        (item as HTMLElement).style.display = 'none';
      }
    });

    // 检查是否有更多内容可以加载
    function hasMoreContent() {
      return visibleCount < allItems.length;
    }

    // 加载更多内容
    function loadMoreContent() {
      if (loading || !hasMoreContent()) return;
      
      loading = true;
      if (loadingIndicator) loadingIndicator.style.display = 'flex';

      // 模拟加载延迟
      setTimeout(() => {
        const nextBatch = Math.min(allItems.length - visibleCount, 8); // 每次加载8个
        
        for (let i = 0; i < nextBatch; i++) {
          const itemToShow = allItems[visibleCount + i] as HTMLElement;
          if (itemToShow) {
            itemToShow.style.display = '';
            // 触发可能的懒加载图片
            const lazyImages = itemToShow.querySelectorAll('img[loading="lazy"]');
            lazyImages.forEach(img => {
              const imgElement = img as HTMLImageElement;
              if (imgElement.dataset.src) {
                imgElement.src = imgElement.dataset.src;
              }
            });
          }
        }
        
        visibleCount += nextBatch;
        loading = false;
        
        if (loadingIndicator) {
          loadingIndicator.style.display = hasMoreContent() ? 'flex' : 'none';
        }
      }, 500);
    }

    // 监听滚动事件，接近底部时加载更多
    function handleScroll() {
      if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 800) {
        loadMoreContent();
      }
    }

    // 添加滚动监听
    window.addEventListener('scroll', handleScroll);
    
    // 初始检查是否需要显示加载指示器
    if (loadingIndicator) {
      loadingIndicator.style.display = hasMoreContent() ? 'flex' : 'none';
    }
  });
</script>