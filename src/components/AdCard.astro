---
import BaseCard from './BaseCard.astro';
---

<BaseCard wrapperClass="content-card-wrapper" cardClass="content-card ad-card">
  <div class="card-image-container">
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7416308426819679"
        crossorigin="anonymous"></script>
      <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-7416308426819679"
         data-ad-slot="3725541876"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
  </div>
</BaseCard>

<style>
  /* 广告卡片特有样式 */
  .ad-card {
    border: 1px dashed #e0e0e0;
  }

  /* 广告占位容器 */
  .ad-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1;
    background: #f9f9f9;
    transition: opacity 0.3s ease;
  }

  /* 确保广告本身可以正确显示 */
  .adsbygoogle {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 5;
  }

  /* 广告标签样式 */
  .ad-label {
    font-size: 0.75rem;
    color: #999;
    background-color: #f5f5f5;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    margin-left: auto;
  }
</style>

<script>
  // 初始化广告代码并处理加载状态
  document.addEventListener('DOMContentLoaded', () => {
    const adCards = document.querySelectorAll('.content-card-wrapper');
    
    adCards.forEach(card => {
      const placeholder = card.querySelector('.ad-placeholder');
      const adElement = card.querySelector('.adsbygoogle');
      
      // 尝试加载广告
      try {
        (adsbygoogle = window.adsbygoogle || []).push({});
        
        // 监听加载状态
        const observer = new MutationObserver((mutations, obs) => {
          // 当广告内容变化时，隐藏占位符
          if (adElement && adElement.innerHTML.trim() !== '' && adElement.offsetHeight > 0) {
            if (placeholder) placeholder.style.opacity = '0';
            obs.disconnect(); // 停止观察
          }
        });
        
        // 配置观察者
        observer.observe(adElement, {
          childList: true,
          subtree: true,
          attributes: true
        });
        
        // 超时处理 - 5秒后如果广告未加载则保持占位符可见
        setTimeout(() => {
          if (adElement.innerHTML.trim() === '' || adElement.offsetHeight <= 1) {
            if (placeholder) {
              const loadingText = placeholder.querySelector('.ad-loading');
              if (loadingText) loadingText.textContent = '广告未能加载';
            }
          }
        }, 5000);
        
      } catch (error) {
        console.error('广告加载失败:', error);
      }
    });
  });
</script>