---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import ArticleCard from '../../components/ArticleCard.astro';

// 获取所有中文文章
const allArticles = await getCollection('articles', ({ data }) => {
  return data.lang === 'zh' && !data.draft;
});

// 按发布日期排序
allArticles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// 分页参数
const articlesPerPage = 30;
---

<BaseLayout
  title="OmniNav - 发现精选深度文章"
  description="OmniNav 是专业的内容精选平台，每日聚合互联网最优质的深度文章与行业分析，通过智能算法为您过滤信息噪音，节省70%的搜索时间。立即体验高效知识获取方式！"
  lang="zh"
>
    <Navbar />
    <main>
        <!-- Article Catalog Section -->
        <section id="articles" class="articles">
            <div class="container">
              {allArticles.map(article => (
                <ArticleCard 
                  article={article} 
                />
              ))}
            </div>
        </section>
    </main>
</BaseLayout>
