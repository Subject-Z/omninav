---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NavigationBar from '../../../components/NavigationBar.astro';
import Pagination from '../../../components/Pagination.astro';
import ListGrid from '../../../components/ListGrid.astro';
import { validCategories, categoryNames, metaTitleNames, getCategoryPagedMetaTitle, getCategoryPagedMetaDescription } from '../../../content/config';
import type { CategoryKey } from '../../../content/config';

export async function getStaticPaths() {
  const paths = [];
  
  for (const category of validCategories) {
    try {
      const typedCategory = category as CategoryKey;
      const categoryContent = await getCollection(typedCategory);
      
      const sortedContent = [...categoryContent].sort((a, b) => {
        const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
        const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
        return dateB - dateA;
      });
      
      const pageSize = 10;
      const totalPages = Math.max(1, Math.ceil(sortedContent.length / pageSize));
      
      // 从第2页开始，第1页已经在[category].astro中处理
      for (let page = 2; page <= totalPages; page++) {
        const startIndex = (page - 1) * pageSize;
        const endIndex = startIndex + pageSize;
        const pageItems = sortedContent.slice(startIndex, endIndex);
        
        paths.push({
          params: { 
            category,
            page: page.toString()
          },
          props: { 
            category,
            items: pageItems,
            currentPage: page,
            totalPages
          }
        });
      }
    } catch (error) {
      console.error(`Error fetching collection ${category}:`, error);
    }
  }
  
  return paths;
}

const { category, items = [], currentPage = 1, totalPages = 1 } = Astro.props;
const typedCategory = category as CategoryKey;

const pageTitle = getCategoryPagedMetaTitle(typedCategory, currentPage);
const pageDescription = getCategoryPagedMetaDescription(typedCategory, currentPage);

function ensureTagsArray(tags: string | string[] | undefined): string[] {
  if (!tags) return [];
  return Array.isArray(tags) ? tags : [tags];
}

const gridItems = items.map(item => ({
  title: item.data.title || "Untitled",
  image: item.data.image,
  tags: ensureTagsArray(item.data.tags),
  category: typedCategory,
  slug: item.slug,
  date: item.data.date,
  description: item.data.description
}));

const baseUrl = `/${typedCategory}`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <NavigationBar />
  
  <main class="page-container">
    <header class="category-header">
    </header>
    
    <ListGrid items={gridItems}/>
    
    <Pagination 
      currentPage={currentPage} 
      totalPages={totalPages} 
      baseUrl={baseUrl} 
    />
  </main>
</BaseLayout>

<style>
  .category-header {
    margin-bottom: 2rem;
    text-align: center;
  }
  
  .category-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
  }
  
  .page-indicator {
    margin-top: 0.5rem;
    font-size: 1.2rem;
    color: #666;
  }
</style>