---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavigationBar from "../components/NavigationBar.astro";
---

<BaseLayout>
    <NavigationBar />

    <main class="container">
        <div class="contact-info-container">
            <h1>About Us</h1>

            <div class="about-section">
                <p>
                    OmniNav is your ultimate guide to exploring Chinese culture!
                    Dive into curated reviews and recommendations for Chinese
                    dramas, movies, anime, games, and novels. Discover authentic
                    cuisine, hidden travel gems, and rich cultural insights—all
                    in one place. Whether you're a film buff, foodie, or travel
                    enthusiast, let OmniNav navigate your journey through
                    China's vibrant traditions and modern trends. Start your
                    cultural adventure today!
                </p>
            </div>

            <div class="contact-section">
                <h2>Contact Information</h2>
                <p>
                    For questions, suggestions, or collaboration opportunities,
                    please reach out to us through:
                </p>
                <div class="contact-methods">
                    <div class="email-container">
                        <a
                            href="mailto:william@omninav.uk"
                            class="contact-link"
                        >
                            <span class="contact-icon">✉️</span>
                            <span id="email-text">william@omninav.uk</span>
                        </a>
                        <button class="copy-btn" id="copy-button">Copy</button>
                    </div>
                </div>
                <p class="contact-note">
                    Click on the email to directly open the mail client, or
                    click the copy button to copy the address.
                </p>
            </div>
        </div>
    </main>
</BaseLayout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const copyButton = document.getElementById("copy-button");
        const emailText = document.getElementById("email-text");

        if (copyButton && emailText) {
            copyButton.addEventListener("click", () => {
                const textToCopy = emailText.textContent || ""; // 添加空值检查，确保始终是字符串
                navigator.clipboard
                    .writeText(textToCopy)
                    .then(() => {
                        const originalText = copyButton.textContent;
                        copyButton.textContent = "Copied!";
                        setTimeout(() => {
                            copyButton.textContent = originalText;
                        }, 2000);
                    })
                    .catch((err) => {
                        console.error("Failed to copy: ", err);
                    });
            });
        }
    });
</script>

<style>
    body {
        background-color: #e6e1d6;
    }

    .container {
        margin: 7rem auto;
        max-width: 800px;
        padding: 0 1rem;
    }

    .contact-info-container {
        background-color: #f5f2ec;
        border-radius: 8px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    h1 {
        color: #2a5caa;
        font-size: 2rem;
        margin-bottom: 1.5rem;
        text-align: center;
    }

    h2 {
        color: #2a5caa;
        font-size: 1.5rem;
        margin: 2rem 0 1rem;
    }

    .about-section,
    .contact-section {
        margin-bottom: 2rem;
    }

    p {
        color: #333;
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .contact-methods {
        margin: 1.5rem 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .email-container {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .contact-link {
        display: flex;
        align-items: center;
        color: #2a5caa;
        text-decoration: none;
        font-size: 1.2rem;
        transition: color 0.2s;
        width: fit-content;
    }

    .contact-link:hover {
        color: #1e4686;
    }

    .contact-icon {
        margin-right: 0.75rem;
        font-size: 1.4rem;
    }

    .contact-note {
        font-size: 0.9rem;
        color: #666;
        font-style: italic;
    }

    .copy-btn {
        background-color: #2a5caa;
        color: white;
        border: none;
        border-radius: 4px;
        padding: 4px 10px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .copy-btn:hover {
        background-color: #1e4686;
    }

    /* Responsive design */
    @media (max-width: 480px) {
        .container {
            margin-top: 5rem;
        }

        .contact-info-container {
            padding: 1.5rem;
        }

        h1 {
            font-size: 1.5rem;
        }

        h2 {
            font-size: 1.3rem;
        }
    }
</style>
