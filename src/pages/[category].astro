---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NavigationBar from '../components/NavigationBar.astro';
import Card from '../components/Card.astro';
import ResponsiveGrid from '../components/ResponsiveGrid.astro';
import { validCategories, categoryNames, metaTitleNames } from '../content/config';
import type { CategoryKey } from '../content/config'; 
import type { CollectionEntry } from 'astro:content';

type ContentItem = CollectionEntry<CategoryKey>;

export async function getStaticPaths() {
  return validCategories.map(category => ({
    params: { category }
  }));
}

const { category } = Astro.params;
const safeCategory = category || '';

if (!validCategories.includes(safeCategory)) {
  return Astro.redirect('/404');
}

const typedCategory = safeCategory as CategoryKey;

const metaCategoryName = metaTitleNames[typedCategory];
const pageTitle = `${metaCategoryName} | OmniNav`;
const pageDescription = `${metaCategoryName}`;

let categoryContent: Array<ContentItem> = [];
try {
  const allContent = await getCollection(typedCategory);
  categoryContent = allContent;
} catch {
}

function ensureTagsArray(tags: string | string[] | undefined): string[] {
  if (!tags) return [];
  return Array.isArray(tags) ? tags : [tags];
}

const gridItems = categoryContent.map(item => ({
  title: item.data.title || "Untitled",
  image: item.data.image,
  tags: ensureTagsArray(item.data.tags),
  category: typedCategory,
  slug: item.slug,
  date: item.data.date
}));
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <NavigationBar />
  
  <main class="page-container">
    <ResponsiveGrid items={gridItems} />
  </main>
</BaseLayout>