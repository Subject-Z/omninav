---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NavigationBar from '../components/NavigationBar.astro';
import ContentList from '../components/ContentList.astro';
import MasonryLayout from '../components/MasonryLayout.astro';
import { validCategories, categoryNames, metaTitleNames } from '../content/config';
import type { CategoryKey } from '../content/config'; 
import type { CollectionEntry } from 'astro:content';

// 定义内容项目类型
type ContentItem = CollectionEntry<CategoryKey>;

// 定义静态路径生成函数
export async function getStaticPaths() {
  return validCategories.map(category => ({
    params: { category }
  }));
}

// 获取当前分类
const { category } = Astro.params;
const safeCategory = category as CategoryKey;

// 如果分类无效，返回404
if (!validCategories.includes(safeCategory)) {
  return Astro.redirect('/404');
}

// 为页面标题使用metaTitleNames
const metaCategoryName = metaTitleNames[safeCategory];
const pageTitle = `${metaCategoryName} | OmniNav`;
const pageDescription = `${metaCategoryName}`;

// 获取当前分类的所有内容
let categoryContent: Array<ContentItem> = [];
try {
  const typedCategory = safeCategory as CategoryKey;
  const allContent = await getCollection(typedCategory);
  
  // 过滤并按发布日期排序
  categoryContent = allContent
    .filter(item => item.data && item.data.date)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
} catch (error) {
  console.error(`Error loading content for ${safeCategory}:`, error);
}

// 确保tags总是数组类型
function ensureTagsArray(tags: string | string[] | undefined): string[] {
  if (!tags) return [];
  return Array.isArray(tags) ? tags : [tags];
}
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <NavigationBar />
  
  <main class="container">
    {categoryContent.length === 0 ? (
      <div class="empty-state">
        该分类暂无内容
      </div>
    ) : (
      <MasonryLayout initialLoadCount={16}>
        {categoryContent.map((item) => (
          <ContentList
            title={item.data.title || "Untitled"}
            description={item.data.description || ""}
            image={item.data.image}
            date={item.data.date}
            tags={ensureTagsArray(item.data.tags)}
            slug={item.slug}
            category={safeCategory}
          />
        ))}
      </MasonryLayout>
    )}
  </main>
</BaseLayout>

<style>
  body {
    background-color: #E6E1D6;
  }

  .container {
    margin: 7rem auto;
    max-width: 1200px;
  }

  .empty-state {
    margin: 3rem auto;
    padding: 3rem 1rem;
    text-align: center;
    color: #777;
    font-size: 1.2rem;
  }
</style>