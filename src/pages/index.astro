---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import NavigationBar from "../components/NavigationBar.astro";
import ContentCard from "../components/ContentCard.astro";
import MasonryLayout from "../components/MasonryLayout.astro";
import { validCategories } from "../content/config";

// 存储所有分类的内容
const allContent = [];

// 获取每个分类的内容
for (const category of validCategories) {
  const typedCategory =
    category as keyof import("astro:content").DataEntryMap;
  const categoryContent = await getCollection(typedCategory).catch(() => []);

  const filteredContent = categoryContent
    .filter((item) => item.data && item.data.date)
    .map((item) => {
      return {
        ...item,
        category,
      };
    });

  allContent.push(...filteredContent);
}

// 按日期从新到旧排序
const sortedContent = allContent.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// 确保tags总是数组类型
function ensureTagsArray(tags: string | string[] | undefined): string[] {
  if (!tags) return [];
  return Array.isArray(tags) ? tags : [tags];
}
---

<BaseLayout>
  <NavigationBar />
  <main class="page-container">
    <MasonryLayout initialLoadCount={16} adInterval={5}>
      {
        sortedContent.map((item) => (
          <ContentCard
            title={item.data.title || "Untitled"}
            description={item.data.description || ""}
            image={item.data.image}
            date={item.data.date}
            tags={ensureTagsArray(item.data.tags)}
            slug={item.slug}
            category={item.category}
          />
        ))
      }
    </MasonryLayout>
  </main>
</BaseLayout>