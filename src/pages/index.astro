---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import NavigationBar from "../components/NavigationBar.astro";
import ResponsiveGrid from "../components/ResponsiveGrid.astro";
import { validCategories } from "../content/config";

const allContent = [];

for (const category of validCategories) {
  const typedCategory =
    category as keyof import("astro:content").DataEntryMap;
  const categoryContent = await getCollection(typedCategory).catch(() => []);

  const filteredContent = categoryContent.map((item) => {
    return {
      ...item,
      category,
    };
  });

  allContent.push(...filteredContent);
}

function shuffleArray<T>(array: T[]): T[] {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}

const randomContent = shuffleArray(allContent);

function ensureTagsArray(tags: string | string[] | undefined): string[] {
  if (!tags) return [];
  return Array.isArray(tags) ? tags : [tags];
}

const gridItems = randomContent.map(item => ({
  title: item.data.title || "Untitled",
  image: item.data.image,
  tags: ensureTagsArray(item.data.tags),
  category: item.category,
  slug: item.slug
}));
---

<BaseLayout>
  <NavigationBar />
  <main class="page-container">
    <ResponsiveGrid items={gridItems} showCategory={true} />
  </main>
</BaseLayout>