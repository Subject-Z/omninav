---
import { getCollection } from "astro:content";
import { pageSize, ensureTagsArray } from "../../content/config";
import { getHomePagedMetaTitle, getHomePagedMetaDescription } from "../../content/config";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SearchBar from "../../components/SearchBar.astro";
import Pagination from "../../components/Pagination.astro";
import ListGrid from "../../components/ListGrid.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  
  let allContent = posts;

  allContent.sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  });

  const totalPages = Math.ceil(allContent.length / pageSize);
  
  const paths = [];
  
  for (let page = 2; page <= totalPages; page++) {
    const startIndex = (page - 1) * pageSize;
    const endIndex = startIndex + pageSize;
    const pageContent = allContent.slice(startIndex, endIndex);
    
    paths.push({
      params: { page: page.toString() },
      props: { 
        page, 
        pageContent, 
        totalPages
      }
    });
  }
  
  return paths;
}

const { page = 1, pageContent = [], totalPages = 1 } = Astro.props;

const gridItems = pageContent.map(item => ({
  title: item.data.title || "Untitled",
  image: item.data.image,
  tags: ensureTagsArray(item.data.tags),
  slug: item.id,
  date: item.data.date,
  description: item.data.description
}));

const metaTitle = getHomePagedMetaTitle(page);
const metaDescription = getHomePagedMetaDescription(page);
const homepageUrl = 'https://www.omninav.uk';
---

<BaseLayout 
  title={metaTitle} 
  description={metaDescription}
  canonicalUrl={homepageUrl}>
  <SearchBar />
  <main class="page-container">
    <header class="category-header">
    </header>
    
    <ListGrid items={gridItems} />
    
    <Pagination
      currentPage={page}
      totalPages={totalPages}
      baseUrl="/"
    />
  </main>
</BaseLayout>

<style>
  .category-header {
    margin-bottom: 2rem;
    text-align: center;
  }
</style>