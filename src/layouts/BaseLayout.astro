---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'en' | 'zh';
  canonicalUrl?: string;
}

const { 
  title = 'OmniNav - Your Intelligent Compass for Navigating the Ocean of Knowledge', 
  description = 'OmniNav is your intelligent compass for exploring the ocean of knowledge, delivering precise recommendations for quality articles, academic resources, and in-depth content to help you acquire valuable information efficiently.',
  lang = 'en',
  canonicalUrl = Astro.url.href,
} = Astro.props;

// 设置HTML文档的语言属性
const htmlLang = lang; // 修复语言设置，直接使用传入的语言
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="OmniNav, knowledge discovery, quality articles, AI recommendations, content curation, academic resources, information filtering, knowledge management" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://chat.deepseek.com/deepseek-chat.jpeg" />
    <meta property="og:site_name" content="OmniNav" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://chat.deepseek.com/deepseek-chat.jpeg" />
    
    <!-- 规范链接 -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" href="/images/favicon.webp" type="image/webp">
    <link rel="apple-touch-icon" href="/images/favicon.webp">
    
    <!-- 移动优化 -->
    <meta name="theme-color" content="#2A5CAA">

    <!-- 结构化数据 (JSON-LD) -->
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "OmniNav",
      "description": "An intelligent knowledge discovery tool that helps users find premium articles and resources.",
      "url": "https://www.omninav.uk",
      "applicationCategory": "EducationApplication"
    }
    </script>
 
    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-MNT4PZEK9C"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MNT4PZEK9C');
    </script>
    
    <!-- Google AdSense -->
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7416308426819679" crossorigin="anonymous"></script>
  </head>
  <body>
    <slot />
  </body>
</html>