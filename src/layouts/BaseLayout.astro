---
import NavigationBar from '../components/NavigationBar.astro';

export interface Props {
  lang: string;
  title?: string;
}

const { lang, title = "Omninav | 一站式智能导航平台" } = Astro.props;

// 获取基本路径 - 适应不同部署环境
const basePath = import.meta.env.BASE_URL || '/';
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="一站式智能导航平台，覆盖AI、生活、信息、娱乐、工具等多个领域 | All-in-one intelligent navigation platform covering AI, lifestyle, information, entertainment, tools and more">
    <link rel="icon" type="image/svg+xml" href={`${basePath}favicon.webp`} />
    <link rel="icon" href={`${basePath}favicon.webp`} type="image/webp" />
    <link rel="apple-touch-icon" href={`${basePath}favicon.webp`} />
    <link rel="shortcut icon" href={`${basePath}favicon.webp`} type="image/webp" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7416308426819679"
    crossorigin="anonymous"></script>

    <!-- 添加调试信息 -->
    <script define:vars={{ basePath, env: import.meta.env.MODE }}>
      console.log(`当前环境: ${env}, 基础路径: ${basePath}`);
    </script>
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site).toString()} />
    <link rel="alternate" hreflang="zh" href={new URL('/zh/', Astro.site).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).toString()} />
  </head>
  <body>
    <NavigationBar lang={lang} />
    <main>
      <slot />
    </main>
   </body>
</html>

<style>
  /* 保持原有样式不变 */
  body {
    background: linear-gradient(180deg, #F3EAE6, #F3EEF6, #EFEEF5, #E6EFF4);
    font-family: system-ui, 'Segoe UI', sans-serif;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  
  main {
    flex: 1;
    padding-top: 13vh;
    width: 100%;
    margin: 0 auto;
  }
  
  @media screen and (max-width: 768px) {
    main {
      padding-top: 10vh;
    }
  }
</style>